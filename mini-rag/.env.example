# Copy this file to .env and fill in your values

# REQUIRED — Gemini API key for generating embeddings
# Get a free key at: https://aistudio.google.com/app/apikey
GEMINI_API_KEY=your_gemini_api_key_here

# OPTIONAL — OpenRouter API key for LLM-generated answers
# Without this, the app still works but shows raw retrieved chunks instead of AI answers
# Get a free key at: https://openrouter.ai
OPENROUTER_API_KEY=your_openrouter_api_key_here

# REQUIRED — Admin secret for protected endpoints (/rebuild-index, /chunks)
# Generate a strong random string, e.g.: python -c "import secrets; print(secrets.token_urlsafe(32))"
ADMIN_SECRET=your_admin_secret_here
